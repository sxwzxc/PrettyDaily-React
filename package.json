{
  "name": "pretty-daily",
  "version": "1.0.0",
  "description": "PrettyDaily - A beautiful daily schedule app with Liquid Glass effects",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:app": "npm run build && npm run build:electron",
    "dist": "npm run build:app && electron-builder --publish never",
    "dist:win": "npm run build:app && electron-builder --win --publish never",
    "dist:mac": "npm run build:app && electron-builder --mac --publish never",
    "dist:linux": "npm run build:app && electron-builder --linux --publish never",
    "lib:build": "npm run lib:clean && npm run lib:esm && npm run lib:cjs && npm run lib:types",
    "lib:esm": "esbuild src/index.tsx --bundle --format=esm --outfile=dist-lib/index.esm.js --external:react --external:react-dom",
    "lib:cjs": "esbuild src/index.tsx --bundle --format=cjs --outfile=dist-lib/index.js --external:react --external:react-dom",
    "lib:types": "tsc -p tsconfig.lib.json --emitDeclarationOnly --outDir dist-lib",
    "lib:clean": "npx rimraf dist-lib"
  },
  "build": {
    "appId": "com.kyant.prettydaily",
    "productName": "PrettyDaily",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "keywords": ["electron", "react", "schedule", "todo", "liquid-glass"],
  "author": "kyant",
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.19.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^8.0.0"
  }
}
